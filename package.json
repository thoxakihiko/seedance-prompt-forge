    "seedance",
    "text-to-video",
    "ai-video",
    "prompt-engineering",
    "prompt-generator",
    "video-generation",
    "cli",
    "kling",
    "runway",
    "veo",
    "sora"
  ],
  "author": "Thox (https://github.com/thoxakihiko)",
  "license": "MIT",
  "homepage": "https://github.com/thoxakihiko/seedance-prompt-forge#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thoxakihiko/seedance-prompt-forge.git"
  },
  "bugs": {
    "url": "https://github.com/thoxakihiko/seedance-prompt-forge/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "src",
    "examples",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ]
